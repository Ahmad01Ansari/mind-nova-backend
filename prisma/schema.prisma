  @@index([userId])
}

model HabitInsight {
  id          String   @id @default(uuid())
  userId      String
  habitId     String?
  insightType String
  title       String
  description String
  impactScore Float?
  metadata    Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model HabitRecommendation {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String
  duration    Int
  isMicro     Boolean  @default(false)
  triggerType String?
  goalType    String
  createdAt   DateTime @default(now())
}

model Challenge {
  id              String          @id @default(uuid())
  title           String
  description     String
  category        String
  durationDays    Int
  difficultyLevel Int             @default(1)
  icon            String          @default("🎯")
  coverGradient   String[]        @default(["#6A0DAD", "#9147FF"])
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  days            ChallengeDay[]
  userChallenges  UserChallenge[]
}

model ChallengeDay {
  id          String          @id @default(uuid())
  challengeId String
  dayNumber   Int
  title       String
  motivation  String
  challenge   Challenge       @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  tasks       ChallengeTask[]

  @@unique([challengeId, dayNumber])
}

model ChallengeTask {
  id          String       @id @default(uuid())
  dayId       String
  title       String
  description String?
  type        String
  duration    Int          @default(2)
  orderIndex  Int          @default(0)
  habitId     String?
  day         ChallengeDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

model UserChallenge {
  id              String                  @id @default(uuid())
  userId          String
  challengeId     String
  startDate       DateTime                @default(now())
  status          String                  @default("ACTIVE")
  currentDay      Int                     @default(1)
  completedAt     DateTime?
  preferredTime   String?
  reminderEnabled Boolean                 @default(true)
  reminderTime    String?
  missedDays      Int                     @default(0)
  lastActiveAt    DateTime                @default(now())
  completionRate  Float                   @default(0.0)
  engagementScore Float                   @default(0.0)
  streakDays      Int                     @default(0)
  adaptationLevel Int                     @default(0)
  abandonReason   String?
  pausedAt        DateTime?
  challenge       Challenge               @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress        UserChallengeProgress[]

  @@index([userId, status])
}

model UserChallengeProgress {
  id                   String        @id @default(uuid())
  userChallengeId      String
  dayNumber            Int
  completed            Boolean       @default(false)
  completedAt          DateTime?
  tasksCompleted       Int           @default(0)
  totalTasks           Int           @default(0)
  completionPercentage Float         @default(0.0)
  userChallenge        UserChallenge @relation(fields: [userChallengeId], references: [id], onDelete: Cascade)

  @@unique([userChallengeId, dayNumber])
}

