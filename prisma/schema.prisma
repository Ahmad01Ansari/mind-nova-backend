  postId      String
  userId      String
  content     String   @db.Text
  parentId    String?
  isAnonymous Boolean  @default(true)
  createdAt   DateTime @default(now())

  post    GroupPost          @relation(fields: [postId], references: [id], onDelete: Cascade)
  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  GroupPostComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies GroupPostComment[] @relation("CommentReplies")

  @@index([postId])
  @@index([userId])
  @@index([parentId])
}

model GroupChatMessage {
  id        String   @id @default(uuid())
  groupId   String
  userId    String
  content   String   @db.Text
  isFlagged Boolean  @default(false)
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([createdAt])
}

model GroupCheckIn {
  id        String   @id @default(uuid())
  groupId   String
  userId    String
  emotion   String
  note      String?  @db.Text
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId, userId, createdAt])
}

model GroupReflection {
  id        String   @id @default(uuid())
  groupId   String
  userId    String
  content   String   @db.Text
  weekOf    DateTime // Start of the week for grouping
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId, weekOf])
}

model GroupChallenge {
  id           String    @id @default(uuid())
  groupId      String
  title        String
  description  String    @db.Text
  durationDays Int
  startDate    DateTime
  endDate      DateTime?
  status       String    @default("ACTIVE") // ACTIVE, COMPLETED
  createdAt    DateTime  @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model GroupInsight {
  id                String   @id @default(uuid())
  groupId           String   @unique
  avgMoodTrend      Json? // Array of mood data points over time
  participationRate Float    @default(0.0)
  healthScore       Float    @default(100.0)
  summaryText       String?  @db.Text
  updatedAt         DateTime @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model GroupExitFeedback {
  id                 String   @id @default(uuid())
  userId             String
  groupId            String
  reason             String   @db.Text
  alternativeGroupId String?
  createdAt          DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

// ─── Habit System ────────────────────────────────────────────────────────────

model Habit {
  id                String    @id @default(uuid())
  userId            String
  title             String
  description       String?
  category          String    // MIND, BODY, FOCUS, RECOVERY, SOCIAL
  duration          Int       @default(1) // duration in minutes
  isMicro           Boolean   @default(false)
  isRoutine         Boolean   @default(false)
  routineType       String?   // MORNING, NIGHT, CUSTOM
  preferredTime     String?   // "08:00"
  triggerType       String?   // "AFTER_WAKEUP", "BEFORE_SLEEP", etc.
  environment       String?   // "HOME", "WORK", "FLEXIBLE"
  difficultyLevel   Int       @default(1) // 1 to 5
  adaptabilityScore Float     @default(1.0)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs              HabitLog[]
  streak            HabitStreak?
  preference        HabitPreference?
  recoveryState     HabitRecoveryState?

  @@index([userId, category])
}

model HabitLog {
  id          String   @id @default(uuid())
  habitId     String
  userId      String
  completedAt DateTime @default(now())
  moodBefore  Int?
  moodAfter   Int?
  note        String?
  duration    Int?     // Actual duration spent

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completedAt])
}

model HabitStreak {
  id               String   @id @default(uuid())
  habitId          String   @unique
  userId           String
  currentStreak    Int      @default(0)
  longestStreak    Int      @default(0)
  consistencyScore Float    @default(0.0)
  lastCompletedAt  DateTime?
  updatedAt        DateTime @updatedAt

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model HabitPreference {
  id             String   @id @default(uuid())
  userId         String
  habitId        String   @unique
  completionRate Float    @default(0.0)
  preferenceScore Float    @default(0.0)
  updatedAt      DateTime @updatedAt

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model HabitRecoveryState {
  id                  String   @id @default(uuid())
  userId              String
  habitId             String   @unique
  missedDays          Int      @default(0)
  recoveryPlanActive  Boolean  @default(false)
  lastRecoveryActionAt DateTime?
  updatedAt           DateTime @updatedAt

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model HabitInsight {
  id          String   @id @default(uuid())
  userId      String
  habitId     String?
  insightType String   // MOOD_IMPACT, CONSISTENCY, PEAK_TIME
  title       String
  description String   @db.Text
  impactScore Float?
  metadata    Json?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model HabitRecommendation {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String
  duration    Int
  isMicro     Boolean  @default(false)
  triggerType String?
  goalType    String   // STRESS, FOCUS, SLEEP, DISCIPLINE, HAPPINESS
  createdAt   DateTime @default(now())
}

// ─── Challenge System ────────────────────────────────────────────────────────

model Challenge {
  id              String         @id @default(uuid())
  title           String
  description     String         @db.Text
  category        String         // MENTAL_HEALTH, FOCUS, RECOVERY, DISCIPLINE
  durationDays    Int            // 3, 5, 7
  difficultyLevel Int            @default(1) // 1-3
  icon            String         @default("🎯")
  coverGradient   String[]       @default(["#6A0DAD", "#9147FF"])
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())

  days            ChallengeDay[]
  userChallenges  UserChallenge[]
}

model ChallengeDay {
  id           String          @id @default(uuid())
  challengeId  String
  dayNumber    Int
  title        String          // "Build Awareness"
  motivation   String          @db.Text  // Daily motivational message

  challenge    Challenge       @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  tasks        ChallengeTask[]

  @@unique([challengeId, dayNumber])
}

model ChallengeTask {
  id          String       @id @default(uuid())
  dayId       String
  title       String
  description String?
  type        String       // HABIT, AUDIO, REFLECTION, BREATHING
  duration    Int          @default(2) // minutes
  orderIndex  Int          @default(0)
  habitId     String?      // Links to Habit system for ecosystem integration

  day         ChallengeDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

model UserChallenge {
  id                String                 @id @default(uuid())
  userId            String
  challengeId       String
  startDate         DateTime               @default(now())
  status            String                 @default("ACTIVE") // ACTIVE, COMPLETED, PAUSED, ABANDONED
  currentDay        Int                    @default(1)
  completedAt       DateTime?
  // Time Awareness
  preferredTime     String?                // "MORNING", "AFTERNOON", "EVENING"
  reminderEnabled   Boolean                @default(true)
  reminderTime      String?                // "08:00" (HH:mm)
  // Drop-Off Recovery
  missedDays        Int                    @default(0)
  lastActiveAt      DateTime               @default(now())
  // Progress Intelligence
  completionRate    Float                  @default(0.0)
  engagementScore   Float                  @default(0.0)
  streakDays        Int                    @default(0)
  // Adaptive Difficulty
  adaptationLevel   Int                    @default(0) // -1 easier, 0 normal, +1 harder
  // Exit Handling
  abandonReason     String?
  pausedAt          DateTime?

  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge         Challenge              @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  progress          UserChallengeProgress[]

  @@index([userId, status])
}

model UserChallengeProgress {
  id                   String        @id @default(uuid())
  userChallengeId      String
  dayNumber            Int
  completed            Boolean       @default(false)
  completedAt          DateTime?
  tasksCompleted       Int           @default(0)
  totalTasks           Int           @default(0)
  completionPercentage Float         @default(0.0) // 0.0 to 1.0

  userChallenge        UserChallenge @relation(fields: [userChallengeId], references: [id], onDelete: Cascade)

  @@unique([userChallengeId, dayNumber])
}
