generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                         @id @default(uuid())
  email                  String?                        @unique
  phone                  String?                        @unique
  passwordHash           String?
  emailVerified          Boolean                        @default(false)
  role                   Role                           @default(USER)
  deviceId               String?                        @unique
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt
  refreshToken           String?
  adaptiveSessions       AdaptiveSession[]
  aiInsights             AiInsight[]
  appointments           Appointment[]                  @relation("PatientAppointments")
  patientReviews         TherapistReview[]              @relation("PatientReviews")
  patientQuestions       TherapistQuestion[]            @relation("PatientQuestions")
  waitlistEntries        WaitlistEntry[]                @relation("PatientWaitlist")
  messageThreads         TherapistMessageThread[]       @relation("UserMessageThreads")
  scores                 AssessmentScore[]
  auditLogs              AuditLog[]
  posts                  CommunityPost[]
  crisisEvents           CrisisEvent[]
  crisisScore            CrisisScore?
  dailySummaries         DailySummary[]
  deviceTokens           DeviceToken[]
  moodLogs               MoodLog[]
  moodStreak             MoodStreak?
  multiDimensionalScores MultiDimensionalScore[]
  notifications          Notification[]
  notificationPref       NotificationPreference?
  personalizedBaseline   PersonalizedBaseline?
  profile                Profile?
  reminderSchedules      ReminderSchedule[]
  subscription           Subscription?
  therapistData          TherapistProfile?
  trustedContacts        TrustedContact[]
  crisisPlan             CrisisPlan?
  weeklyReports          WeeklyReport[]
  gratitudeEntries       GratitudeEntry[]
  gratitudeMemories      GratitudeMemory[]
  gratitudeStreak        GratitudeStreak?
  journalEntries         JournalEntry[]
  journalStreak          JournalStreak?
  groundingSessions      GroundingSession[]
  groundingStreak        GroundingStreak?
  groundingFavorites     GroundingFavoriteEnvironment[]
  groundingAnalytics     GroundingAnalytics?

  // Meditation
  meditationSessions  MeditationSession[]
  meditationStreak    MeditationStreak?
  meditationAnalytics MeditationAnalytics?
  meditationFavorites MeditationFavorite[]
  meditationDownloads MeditationDownload[]

  // Audio
  audioHistory   UserAudioHistory[]
  audioDownloads DownloadedAudioTrack[]

  // Focus
  focusSessions FocusSession[]
  focusStats    FocusStats?

  // Community Rooms
  communityRoomsJoined RoomParticipant[]
  communityAliases     AnonymousAlias[]
  roomReminders        RoomReminder[]

  // Community Feed
  postReactions PostReaction[]
  postComments  PostComment[]
  postReports   PostReport[]
  postBookmarks PostBookmark[]

  // Groups
  groupsJoined       GroupMember[]
  groupPosts         GroupPost[]
  groupPostReactions GroupPostReaction[]
  groupPostComments  GroupPostComment[]
  groupChatMessages  GroupChatMessage[]
  groupCheckIns      GroupCheckIn[]
  groupReflections   GroupReflection[]
  groupExitFeedbacks GroupExitFeedback[]

  // Recovery
  recoveryLogs          RecoveryLog[]
  recoveryScore         RecoveryScore?
  recoveryPreferences   RecoveryPreference[]
  recoveryEffectiveness RecoveryEffectiveness[]

  // Habits
  habits              Habit[]
  habitLogs           HabitLog[]
  habitStreaks        HabitStreak[]
  habitInsights       HabitInsight[]
  habitPreferences    HabitPreference[]
  habitRecoveryStates HabitRecoveryState[]

  // Challenges
  userChallenges      UserChallenge[]
  aiUsage             AiUsage[]
}

model AiUsage {
  id        String   @id @default(uuid())
  userId    String
  count     Int      @default(0)
  date      DateTime @db.Date
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model EmailVerification {
  id        String   @id @default(uuid())
  email     String   @unique
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Profile {
  id             String    @id @default(uuid())
  userId         String    @unique
  firstName      String?
  lastName       String?
  dob            DateTime?
  avatarUrl      String?
  gender         String?
  ageRange       String?
  goals          String[]
  baselineStress Float?
  baselineSleep  Float?
  baselineMood   Float?
  onboarding     Boolean   @default(false)
  height         Float?
  weight         Float?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Assessment {
  id          String            @id @default(uuid())
  title       String            @unique
  description String?
  type        String
  scores      AssessmentScore[]
}

model AssessmentScore {
  id            String     @id @default(uuid())
  userId        String
  assessmentId  String
  totalScore    Int
  severityLevel String
  insight       String?
  metadata      Json?
  createdAt     DateTime   @default(now())
  assessment    Assessment @relation(fields: [assessmentId], references: [id])
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MoodLog {
  id           String    @id @default(uuid())
  userId       String
  score        Int
  energy       Int?
  stress       Int?
  anxiety      Int?
  sleepHours   Float?
  sleepQuality Int?
  note         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags         MoodTag[]

  @@index([userId, createdAt(sort: Desc)])
}

model MoodTag {
  id        String  @id @default(uuid())
  name      String
  moodLogId String
  moodLog   MoodLog @relation(fields: [moodLogId], references: [id], onDelete: Cascade)

  @@index([moodLogId])
}

model MoodStreak {
  id            String    @id @default(uuid())
  userId        String    @unique
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastLogDate   DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DailySummary {
  id              String   @id @default(uuid())
  userId          String
  date            DateTime @db.Date
  avgScore        Float
  volatilityScore Float?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model CommunityPost {
  id              String   @id @default(uuid())
  userId          String
  aliasName       String? // Snapshot of anonymous alias at post time
  content         String   @db.Text
  emotion         String // SAD, ANXIOUS, FRUSTRATED, TIRED, HAPPY, LONELY, STRESSED
  type            String   @default("STANDARD") // STANDARD, HELP_ME, GRATITUDE
  needType        String? // VENT, ADVICE, SUPPORT, RELATE
  tags            String[] // e.g. ["study", "breakup", "career"]
  isAnonymous     Boolean  @default(true)
  visibilityScore Float    @default(0.0)
  isFlagged       Boolean  @default(false)
  flagReason      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions PostReaction[]
  comments  PostComment[]
  reports   PostReport[]
  bookmarks PostBookmark[]

  @@index([userId])
  @@index([emotion])
  @@index([type])
  @@index([visibilityScore])
  @@index([createdAt])
}

model PostReaction {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  type      String // SUPPORT, HUG, STAY_STRONG, FEEL_SAME
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, type])
  @@index([postId])
  @@index([userId])
}

model PostComment {
  id          String   @id @default(uuid())
  postId      String
  userId      String
  aliasName   String?
  content     String   @db.Text
  parentId    String? // For single-level nesting only
  isAnonymous Boolean  @default(true)
  isFlagged   Boolean  @default(false)
  createdAt   DateTime @default(now())

  post    CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  PostComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies PostComment[] @relation("CommentReplies")

  @@index([postId])
  @@index([userId])
  @@index([parentId])
}

model PostReport {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  reason    String
  status    String   @default("PENDING") // PENDING, REVIEWED, DISMISSED
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
}

model PostBookmark {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
}

model Subscription {
  id          String   @id @default(uuid())
  userId      String   @unique
  stripeSubId String?  @unique
  status      String
  validUntil  DateTime
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TherapistProfile {
  id                String    @id @default(uuid())
  userId            String    @unique // The user account of the therapist
  name              String? // Explicit name if different from User profile
  title             String? // e.g., "Clinical Psychologist"
  specialty         String
  languages         String[]  @default([])
  hourlyRate        Float // Keep as base price
  priceQuick        Float     @default(499) // 15-min consult
  priceDeep         Float     @default(999) // 45-min session
  priceStudent      Float     @default(299) // Student discounted rate
  bio               String?
  imageUrl          String? // Profile photo URL
  availableHours    Json?
  styleTags         String[]  @default([]) // e.g. ["Warm listener", "Direct coach"]
  isVerified        Boolean   @default(false)
  isActive          Boolean   @default(true)
  experienceYrs     Int       @default(0)
  rating            Float     @default(5.0)
  responseTime      String? // e.g. "Usually replies in 2 hrs"
  sessionsCompleted Int       @default(0)
  onlineStatus      String    @default("OFFLINE") // "ONLINE", "BUSY", "OFFLINE"
  lastActiveAt      DateTime?
  supportedModes    String[]  @default(["CHAT", "VOICE", "VIDEO"])
  studentFriendly   Boolean   @default(false)
  isConfidential    Boolean   @default(true)

  // SLA Tracking
  avgResponseTimeMins    Int   @default(0)
  acceptRate             Float @default(100.0)
  cancelledSessionsCount Int   @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  appointments         Appointment[]
  reviews              TherapistReview[]
  questions            TherapistQuestion[]
  waitlistEntries      WaitlistEntry[]
  availability         TherapistAvailability[]
  messageThreads       TherapistMessageThread[] @relation("TherapistMessageThreads")
  TherapistBlockedDate TherapistBlockedDate[]
}

model TherapistAvailability {
  id            String    @id @default(uuid())
  therapistId   String
  dayOfWeek     String // "MON", "TUE", "WED", "THU", "FRI", "SAT", "SUN"
  startTime     String // "17:00" (24hr format)
  endTime       String // "19:00"
  mode          String    @default("CHAT") // "CHAT", "VOICE", "VIDEO"
  isRecurring   Boolean   @default(true)
  specificDate  DateTime? @db.Date // For one-off availability overrides
  bufferMinutes Int       @default(15)

  therapist TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([therapistId])
}

model TherapistBlockedDate {
  id          String   @id @default(uuid())
  therapistId String
  date        DateTime @db.Date
  reason      String? // e.g., "Holiday", "Personal Leave"

  therapist TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([therapistId, date])
}

model TherapistMessageThread {
  id          String   @id @default(uuid())
  userId      String
  therapistId String
  category    String? // "Anxiety", "Relationship", "Career", "Stress", "Academic", "Other"
  subject     String?
  status      String   @default("OPEN") // OPEN, CLOSED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User               @relation("UserMessageThreads", fields: [userId], references: [id], onDelete: Cascade)
  therapist TherapistProfile   @relation("TherapistMessageThreads", fields: [therapistId], references: [id], onDelete: Cascade)
  messages  TherapistMessage[]

  @@index([userId])
  @@index([therapistId])
}

model TherapistMessage {
  id          String    @id @default(uuid())
  threadId    String
  senderType  String // "USER" or "THERAPIST"
  senderId    String
  messageType String    @default("TEXT") // "TEXT", "VOICE", "IMAGE", "FILE"
  content     String    @db.Text
  fileUrl     String?
  duration    Int? // voice note duration in seconds
  status      String    @default("SENT") // "SENT", "DELIVERED", "SEEN"
  seenAt      DateTime?
  createdAt   DateTime  @default(now())

  thread TherapistMessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

model Appointment {
  id            String   @id @default(uuid())
  patientId     String
  therapistId   String
  date          DateTime
  durationMin   Int      @default(45)
  type          String   @default("VIDEO_CALL") // "VIDEO_CALL", "VOICE", "WHATSAPP"
  status        String   @default("REQUESTED") // REQUESTED, CONFIRMED, RESCHEDULE_REQUESTED, CANCELLED, COMPLETED
  aiSummary     String?  @db.Text
  notes         String?  @db.Text // User notes with booking request
  preferredSlot String? // "Morning", "Afternoon", "Evening"
  guestName     String? // For guest/unauthenticated bookings (lead capture)
  guestPhone    String? // Guest phone for contact
  guestEmail    String? // Guest email for follow-up
  reflection    Json? // Post-session feedback

  // ─── Scheduling Details ────────────────────────────────────
  scheduledStartTime DateTime?
  scheduledEndTime   DateTime?
  timezone           String    @default("Asia/Kolkata")

  // ─── Cancellation Policy ───────────────────────────────────
  cancelledAt          DateTime?
  cancelledBy          String? // "USER", "THERAPIST", "ADMIN"
  refundEligibleLater  Boolean   @default(false)
  lateCancellationFlag Boolean   @default(false)

  // ─── Client Insights Consent ───────────────────────────────
  shareMood        Boolean @default(false)
  shareSleep       Boolean @default(false)
  shareAssessments Boolean @default(false)
  shareJournal     Boolean @default(false)

  // ─── Revenue Tracking ──────────────────────────────────────
  price         Float? // Final charged price
  discount      Float? @default(0) // Discount applied
  commission    Float? @default(0) // Platform commission
  paymentStatus String @default("UNPAID") // UNPAID, PAID, REFUNDED
  sourceChannel String @default("APP") // APP, WHATSAPP, REFERRAL

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient   User             @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  therapist TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([therapistId, date])
  @@index([patientId, status])
}

model TherapistReview {
  id          String   @id @default(uuid())
  patientId   String
  therapistId String
  rating      Int
  text        String?
  createdAt   DateTime @default(now())

  patient   User             @relation("PatientReviews", fields: [patientId], references: [id], onDelete: Cascade)
  therapist TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)
}

model TherapistQuestion {
  id          String    @id @default(uuid())
  patientId   String
  therapistId String
  question    String    @db.Text
  answer      String?   @db.Text
  isAnonymous Boolean   @default(false)
  status      String    @default("PENDING") // PENDING, ANSWERED
  createdAt   DateTime  @default(now())
  answeredAt  DateTime?

  patient   User             @relation("PatientQuestions", fields: [patientId], references: [id], onDelete: Cascade)
  therapist TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)
}

model WaitlistEntry {
  id          String   @id @default(uuid())
  patientId   String
  therapistId String
  status      String   @default("WAITING") // WAITING, NOTIFIED, COMPLETED
  createdAt   DateTime @default(now())

  patient   User             @relation("PatientWaitlist", fields: [patientId], references: [id], onDelete: Cascade)
  therapist TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model WeeklyReport {
  id            String   @id @default(uuid())
  userId        String
  weekStartDate DateTime @db.Date
  weekEndDate   DateTime @db.Date

  // ── Mood Analytics ──
  avgMoodScore Float
  bestMoodDay  String?
  worstMoodDay String?
  moodTrend    String  @default("FLAT")
  moodLogCount Int     @default(0)

  // ── Sleep ──
  avgSleepHours    Float?
  sleepConsistency Float?

  // ── Predictions ──
  stressAvg       Float?
  burnoutRisk     Float?
  anxietyTrend    Float?
  depressionTrend Float?

  // ── Engagement Metrics ──
  gratitudeCount    Int @default(0)
  journalCount      Int @default(0)
  meditationMinutes Int @default(0)
  groundingSessions Int @default(0)
  audioMinutes      Int @default(0)

  // ── Composite Scores ──
  emotionalVolatility Float?
  recoveryScore       Float?
  wellnessScore       Float?
  engagementScore     Float?
  cmhiWeeklyScore     Float?
  streakScore         Int    @default(0)

  // ── AI Derived ──
  aiSummary         String   @db.Text
  aiTitle           String?
  aiWhatHelped      String?  @db.Text
  aiChallenges      String?  @db.Text
  aiComparison      String?  @db.Text
  aiRecommendations String[]
  aiEncouragement   String?

  // ── Previous Week Comparison ──
  previousWellnessScore Float?
  previousMoodScore     Float?
  weekDelta             Float?
  improved              Boolean?

  // ── Safety ──
  crisisRiskLevel String @default("LOW")

  // ── Confidence & Metadata ──
  dataCompleteness Float     @default(0)
  dataConfidence   String    @default("STARTER")
  lastSleepLogAt   DateTime?
  reportVersion    String    @default("2.0")
  isShared         Boolean   @default(false)
  isExported       Boolean   @default(false)
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStartDate])
  @@index([userId, createdAt])
}

model Notification {
  id            String    @id @default(uuid())
  userId        String
  type          String
  title         String
  body          String
  category      String
  priority      String    @default("MEDIUM")
  channel       String    @default("PUSH")
  scheduledAt   DateTime
  sentAt        DateTime?
  readAt        DateTime?
  deepLink      String?
  metadata      Json?
  retryCount    Int       @default(0)
  failureReason String?
  expiresAt     DateTime?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([scheduledAt, sentAt])
  @@index([category])
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model NotificationPreference {
  id                  String   @id @default(uuid())
  userId              String   @unique
  moodReminders       Boolean  @default(true)
  sleepReminders      Boolean  @default(true)
  assessmentReminders Boolean  @default(true)
  weeklyReportAlerts  Boolean  @default(true)
  streakAlerts        Boolean  @default(true)
  therapyReminders    Boolean  @default(true)
  meditationReminders Boolean  @default(false)
  journalReminders    Boolean  @default(false)
  communityAlerts     Boolean  @default(true)
  marketingAlerts     Boolean  @default(false)
  quietHoursStart     String?
  quietHoursEnd       String?
  timezone            String   @default("UTC")
  moodReminderTime    String   @default("20:00")
  sleepReminderTime   String   @default("22:30")
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReminderSchedule {
  id            String    @id @default(uuid())
  userId        String
  reminderType  String
  scheduledTime String
  daysOfWeek    String[]
  isActive      Boolean   @default(true)
  snoozedUntil  DateTime?
  lastFiredAt   DateTime?
  nextFireAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, reminderType])
  @@index([nextFireAt, isActive])
}

model CrisisEvent {
  id          String          @id @default(uuid())
  userId      String
  riskLevel   CrisisRiskLevel
  category    CrisisCategory
  triggerText String?
  source      String
  latitude    Float?
  longitude   Float?
  accuracy    Float?
  isHandled   Boolean         @default(false)
  handledAt   DateTime?
  adminNotes  String?
  createdAt   DateTime        @default(now())
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model CrisisScore {
  id            String          @id @default(uuid())
  userId        String          @unique
  score         Float           @default(0.0)
  lastRiskLevel CrisisRiskLevel @default(LOW)
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CrisisPlan {
  id             String   @id @default(uuid())
  userId         String   @unique
  warningSigns   String[] @default([])
  calmingActions String[] @default([])
  reasonsToStay  String[] @default([])
  safePlaces     String[] @default([])
  notes          String?
  version        Int      @default(1)
  isGuestBackup  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TrustedContact {
  id            String    @id @default(uuid())
  userId        String
  name          String
  relation      String?
  phoneNumber   String
  isVerified    Boolean   @default(false)
  priority      Int       @default(0)
  allowQuickSms Boolean   @default(false)
  favorite      Boolean   @default(false)
  verifiedAt    DateTime?
  lastUsedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmergencyResource {
  id          String         @id @default(uuid())
  name        String
  description String?
  phoneNumber String
  website     String?
  countryCode String
  regionCode  String?
  category    CrisisCategory @default(OTHER)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([countryCode, regionCode])
}

model AdaptiveSession {
  id                String             @id @default(uuid())
  userId            String
  mode              AssessmentMode     @default(STANDARD)
  status            AssessmentStatus   @default(IN_PROGRESS)
  currentScore      Float              @default(0.0)
  dimensionalScores Json?
  crisisFlag        Boolean            @default(false)
  startedAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  expiresAt         DateTime?
  completedAt       DateTime?
  responses         AdaptiveResponse[]
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model AdaptiveResponse {
  id         String          @id @default(uuid())
  sessionId  String
  questionId String
  score      Float?
  textValue  String?
  timeTaken  Int?
  createdAt  DateTime        @default(now())
  session    AdaptiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
